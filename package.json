{
  "name": "cisco-cli-lexique",
  "version": "1.1.0",
  "description": "Lexique Cisco CLI installable en PWA et empaquetable en application desktop.",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "desktop": "electron .",
    "build:mac": "electron-builder --mac --publish=never",
    "build:android:twa": "bubblewrap build",
    "mobile:prepare": "node tools/prepare-mobile.mjs",
    "mobile:sync": "pnpm run mobile:prepare && cap sync android",
    "mobile:open": "cap open android",
    "test": "node tools/validate-data.mjs"
  },
  "build": {
    "appId": "fr.hugo.ciscoclilexique",
    "productName": "Lexique Cisco CLI",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "data.js",
      "manifest.webmanifest",
      "sw.js",
      "icon.svg",
      "icons/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icons/icon-512.png"
    }
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@bubblewrap/cli": "^1.22.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
